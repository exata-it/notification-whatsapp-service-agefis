generator client {
  provider   = "prisma-client"
  output     = "./generated/prisma"
  engineType = "client"
  runtime    = "bun"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model AppRelease {
  id          String   @id @default(uuid(7))
  platform    String
  version     String
  // Derivado da versão (major*1e6 + minor*1e3 + patch) — mesma fórmula do
  // versionCode que o Tauri gera para o Android. Ordenação de releases.
  versionCode Int
  // Chave do objeto no bucket MinIO (ex.: android/0.4.0/app-arm64.apk)
  objectKey   String
  sha256      String
  size        Int
  force       Boolean  @default(false)
  // Rollback: desativar release ruim faz o /latest voltar à anterior
  active      Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([platform, version])
  @@index([platform, active, versionCode])
  @@map("app_releases")
  @@schema("public")
}
